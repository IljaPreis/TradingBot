//@version=6
indicator("TradingBot V20 Signal Engine", overlay=true)
ema20=ta.ema(close,20)
ema50=ta.ema(close,50)
ema200=ta.ema(close,200)
vwapVal=ta.vwap(close)
atrVal=ta.atr(14)
volSpike=volume>ta.sma(volume,20)*1.2
plot(ema20,"EMA20",color=color.orange)
plot(ema50,"EMA50",color=color.blue)
plot(ema200,"EMA200",color=color.purple)
plot(vwapVal,"VWAP",color=color.aqua)
ph=ta.pivothigh(high,5,5)
pl=ta.pivotlow(low,5,5)
lastPH=ta.valuewhen(not na(ph),ph,0)
lastPL=ta.valuewhen(not na(pl),pl,0)
bosLong=not na(lastPH) and close>lastPH
bosShort=not na(lastPL) and close<lastPL
sweepLong=low<ta.lowest(low,20)[1] and close>open
sweepShort=high>ta.highest(high,20)[1] and close<open
fvgLong=low>high[2]
fvgShort=high<low[2]
trendLong=ema20>ema50 and ema50>ema200 and close>ema200
trendShort=ema20<ema50 and ema50<ema200 and close<ema200
longSignal=barstate.isconfirmed and close>ema20 and low<=ema20 and trendLong and close>vwapVal and (volSpike or bosLong or sweepLong)
shortSignal=barstate.isconfirmed and close<ema20 and high>=ema20 and trendShort and close<vwapVal and (volSpike or bosShort or sweepShort)
h=hour(time,"Europe/Berlin")
sess=h>=1 and h<8?"Asia":h>=8 and h<14?"London":h>=14 and h<22?"NewYork":"Off"
structL=bosLong?"bos":sweepLong?"sweep":fvgLong?"fvg":"none"
structS=bosShort?"bos":sweepShort?"sweep":fvgShort?"fvg":"none"
base=math.max(atrVal*1.2, syminfo.type=="forex"?0.002:50)
if longSignal
    alert('{"market":"'+syminfo.ticker+'","side":"long","price":'+str.tostring(close)+',"trigger":"ema20_reclaim","timeframe":"'+timeframe.period+'","trend_state":"long_trend","volume_state":"'+(volSpike?"spike":"normal")+'","vwap_state":"above_vwap","structure_state":"'+structL+'","session":"'+sess+'","atr":'+str.tostring(atrVal)+',"sl":'+str.tostring(close-base)+',"tp1":'+str.tostring(close+base*1.5)+',"tp2":'+str.tostring(close+base*3)+',"tp3":'+str.tostring(close+base*4.5)+'}',alert.freq_once_per_bar_close)
if shortSignal
    alert('{"market":"'+syminfo.ticker+'","side":"short","price":'+str.tostring(close)+',"trigger":"ema20_breakdown","timeframe":"'+timeframe.period+'","trend_state":"short_trend","volume_state":"'+(volSpike?"spike":"normal")+'","vwap_state":"below_vwap","structure_state":"'+structS+'","session":"'+sess+'","atr":'+str.tostring(atrVal)+',"sl":'+str.tostring(close+base)+',"tp1":'+str.tostring(close-base*1.5)+',"tp2":'+str.tostring(close-base*3)+',"tp3":'+str.tostring(close-base*4.5)+'}',alert.freq_once_per_bar_close)
plotshape(longSignal,style=shape.labelup,text="LONG",color=color.green,textcolor=color.white)
plotshape(shortSignal,style=shape.labeldown,text="SHORT",color=color.red,textcolor=color.white)
